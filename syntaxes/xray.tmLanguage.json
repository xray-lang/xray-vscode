{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Xray",
  "scopeName": "source.xray",
  "patterns": [
    { "include": "#comments" },
    { "include": "#decorators" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#declarations" },
    { "include": "#generic-types" },
    { "include": "#stdlib-module" },
    { "include": "#types" },
    { "include": "#constants" },
    { "include": "#operators" },
    { "include": "#functions" },
    { "include": "#variables" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.xray",
          "match": "//.*$"
        },
        {
          "name": "comment.block.xray",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "decorators": {
      "patterns": [
        {
          "name": "meta.decorator.xray",
          "match": "@([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "0": { "name": "entity.name.decorator.xray" }
          }
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.xray",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.xray",
              "match": "\\\\(x[0-9A-Fa-f]{2}|u\\{[0-9A-Fa-f]+\\}|u[0-9A-Fa-f]{4}|[0-7]{1,3}|[nrt\\\\'\"`0abfv])"
            },
            {
              "name": "invalid.illegal.escape.xray",
              "match": "\\\\."
            },
            {
              "name": "meta.embedded.expression.xray",
              "begin": "\\$\\{",
              "end": "\\}",
              "beginCaptures": {
                "0": { "name": "punctuation.definition.template-expression.begin.xray" }
              },
              "endCaptures": {
                "0": { "name": "punctuation.definition.template-expression.end.xray" }
              },
              "patterns": [
                { "include": "$self" }
              ]
            }
          ]
        },
        {
          "name": "string.quoted.single.xray",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.xray",
              "match": "\\\\(x[0-9A-Fa-f]{2}|u\\{[0-9A-Fa-f]+\\}|u[0-9A-Fa-f]{4}|[0-7]{1,3}|[nrt\\\\'\"`0abfv])"
            },
            {
              "name": "invalid.illegal.escape.xray",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.raw.double.xray",
          "begin": "r\"",
          "end": "\""
        },
        {
          "name": "string.raw.single.xray",
          "begin": "r'",
          "end": "'"
        },
        {
          "name": "string.regexp.xray",
          "begin": "(?<=[=(,:\\[!&|?])\\s*/(?![/*\\s])",
          "end": "/[gimsuy]*",
          "patterns": [
            {
              "name": "constant.character.escape.xray",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.xray",
          "match": "\\b0[xX][0-9a-fA-F_]+\\b"
        },
        {
          "name": "constant.numeric.binary.xray",
          "match": "\\b0[bB][01_]+\\b"
        },
        {
          "name": "constant.numeric.octal.xray",
          "match": "\\b0[oO][0-7_]+\\b"
        },
        {
          "name": "constant.numeric.float.xray",
          "match": "\\b[0-9][0-9_]*\\.[0-9][0-9_]*([eE][+-]?[0-9_]+)?\\b"
        },
        {
          "name": "constant.numeric.bigint.xray",
          "match": "\\b[0-9][0-9_]*n\\b"
        },
        {
          "name": "constant.numeric.integer.xray",
          "match": "\\b[0-9][0-9_]*\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "comment": "shared declaration: shared NAME = ... (highlight modifier + declarator together)",
          "match": "\\b(shared)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\b",
          "captures": {
            "1": { "name": "storage.modifier.shared.xray" },
            "2": { "name": "variable.other.declaration.xray" }
          }
        },
        {
          "comment": "owned declaration: owned NAME = ... (highlight modifier + declarator together)",
          "match": "\\b(owned)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\b",
          "captures": {
            "1": { "name": "storage.modifier.owned.xray" },
            "2": { "name": "variable.other.declaration.xray" }
          }
        },
        {
          "name": "keyword.control.xray",
          "match": "\\b(if|else|while|for|in|is|to|break|continue|return|match|default|yield)\\b"
        },
        {
          "name": "keyword.declaration.var.xray",
          "match": "\\bvar\\b"
        },
        {
          "name": "keyword.declaration.const.xray",
          "match": "\\bconst\\b"
        },
        {
          "name": "keyword.declaration.function.xray",
          "match": "\\bfn\\b"
        },
        {
          "name": "keyword.declaration.type.xray",
          "match": "\\b(class|struct|packed|union|interface|enum|type)\\b"
        },
        {
          "name": "storage.modifier.xray",
          "match": "\\b(static|private|protected|shared|final|comptime|unsafe)\\b"
        },
        {
          "name": "keyword.operator.overload.xray",
          "match": "\\boperator\\b"
        },
        {
          "name": "keyword.class.xray",
          "match": "\\b(extends|implements|constructor|this|super|new)\\b"
        },
        {
          "name": "keyword.exception.xray",
          "match": "\\b(try|catch|throw|panic)\\b"
        },
        {
          "name": "keyword.module.xray",
          "match": "\\b(import|export|from|as)\\b"
        },
        {
          "name": "keyword.concurrency.xray",
          "match": "\\b(go|await|select|defer|scope|linked|supervisor|cancelled|after|ref|out|move)\\b"
        },
        {
          "name": "keyword.other.xray",
          "match": "\\b(_)\\b"
        }
      ]
    },
    "declarations": {
      "patterns": [
        {
          "comment": "Class declaration: class Point { ... }",
          "match": "\\b(class)\\s+([A-Z][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.xray" },
            "2": { "name": "entity.name.type.class.xray" }
          }
        },
        {
          "comment": "Enum declaration: enum Color { ... }",
          "match": "\\b(enum)\\s+([A-Z][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.xray" },
            "2": { "name": "entity.name.type.enum.xray" }
          }
        },
        {
          "comment": "Interface declaration: interface Iterable { ... }",
          "match": "\\b(interface)\\s+([A-Z][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.xray" },
            "2": { "name": "entity.name.type.interface.xray" }
          }
        },
        {
          "comment": "Type alias declaration: type Point = { ... }",
          "match": "\\b(type)\\s+([A-Z][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.xray" },
            "2": { "name": "entity.name.type.alias.xray" }
          }
        }
      ]
    },
    "generic-types": {
      "patterns": [
        {
          "comment": "Generic class definition: class Box<T>, class Foo<T: Comparable & Hashable, U>",
          "match": "\\b(class)\\s+([A-Z][a-zA-Z0-9_]*)\\s*(<)([A-Z][a-zA-Z0-9_]*(?:\\s*:\\s*[A-Z][a-zA-Z0-9_]*(?:\\s*&\\s*[A-Z][a-zA-Z0-9_]*)*)?(?:\\s*,\\s*[A-Z][a-zA-Z0-9_]*(?:\\s*:\\s*[A-Z][a-zA-Z0-9_]*(?:\\s*&\\s*[A-Z][a-zA-Z0-9_]*)*)?)*)(>)",
          "captures": {
            "1": { "name": "keyword.declaration.xray" },
            "2": { "name": "entity.name.type.class.xray" },
            "3": { "name": "punctuation.definition.typeparameters.begin.xray" },
            "4": { "name": "entity.name.type.parameter.xray" },
            "5": { "name": "punctuation.definition.typeparameters.end.xray" }
          }
        },
        {
          "comment": "Generic function definition: fn foo<T>(x: T), fn bar<T: Comparable & Hashable>(x: T)",
          "match": "\\b(fn)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*(<)([A-Z][a-zA-Z0-9_]*(?:\\s*:\\s*[A-Z][a-zA-Z0-9_]*(?:\\s*&\\s*[A-Z][a-zA-Z0-9_]*)*)?(?:\\s*,\\s*[A-Z][a-zA-Z0-9_]*(?:\\s*:\\s*[A-Z][a-zA-Z0-9_]*(?:\\s*&\\s*[A-Z][a-zA-Z0-9_]*)*)?)*)(>)",
          "captures": {
            "1": { "name": "keyword.declaration.xray" },
            "2": { "name": "entity.name.function.xray" },
            "3": { "name": "punctuation.definition.typeparameters.begin.xray" },
            "4": { "name": "entity.name.type.parameter.xray" },
            "5": { "name": "punctuation.definition.typeparameters.end.xray" }
          }
        },
        {
          "comment": "Generic static method: static identity<T>(x: T), static foo<T: Comparable>(x: T)",
          "match": "\\b(static)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*(<)([A-Z][a-zA-Z0-9_]*(?:\\s*:\\s*[A-Z][a-zA-Z0-9_]*(?:\\s*&\\s*[A-Z][a-zA-Z0-9_]*)*)?(?:\\s*,\\s*[A-Z][a-zA-Z0-9_]*(?:\\s*:\\s*[A-Z][a-zA-Z0-9_]*(?:\\s*&\\s*[A-Z][a-zA-Z0-9_]*)*)?)*)(>)",
          "captures": {
            "1": { "name": "keyword.class.xray" },
            "2": { "name": "entity.name.function.xray" },
            "3": { "name": "punctuation.definition.typeparameters.begin.xray" },
            "4": { "name": "entity.name.type.parameter.xray" },
            "5": { "name": "punctuation.definition.typeparameters.end.xray" }
          }
        },
        {
          "comment": "Generic method definition: add<T>(item: T), add<T: Comparable & Hashable>(item: T)",
          "match": "^\\s*([a-zA-Z_][a-zA-Z0-9_]*)\\s*(<)([A-Z][a-zA-Z0-9_]*(?:\\s*:\\s*[A-Z][a-zA-Z0-9_]*(?:\\s*&\\s*[A-Z][a-zA-Z0-9_]*)*)?(?:\\s*,\\s*[A-Z][a-zA-Z0-9_]*(?:\\s*:\\s*[A-Z][a-zA-Z0-9_]*(?:\\s*&\\s*[A-Z][a-zA-Z0-9_]*)*)?)*)(>)\\s*(?=\\()",
          "captures": {
            "1": { "name": "entity.name.function.xray" },
            "2": { "name": "punctuation.definition.typeparameters.begin.xray" },
            "3": { "name": "entity.name.type.parameter.xray" },
            "4": { "name": "punctuation.definition.typeparameters.end.xray" }
          }
        },
        {
          "comment": "Generic type annotation: Box<int>, Channel<string>, Array<T>",
          "match": "\\b([A-Z][a-zA-Z0-9_]*)(<)([^<>]+(?:<[^<>]+>)?)(>)",
          "captures": {
            "1": { "name": "support.type.builtin.xray" },
            "2": { "name": "punctuation.definition.typeparameters.begin.xray" },
            "3": { "name": "support.type.xray" },
            "4": { "name": "punctuation.definition.typeparameters.end.xray" }
          }
        },
        {
          "comment": "Nullable type: int?, string?",
          "match": "\\b(int|float|string|bool|byte|rune|[A-Z][a-zA-Z0-9_]*)(\\?)",
          "captures": {
            "1": { "name": "support.type.xray" },
            "2": { "name": "keyword.operator.nullable.xray" }
          }
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "comment": "Type cast functions: int(), float(), string(), bool()",
          "name": "support.function.builtin.xray",
          "match": "\\b(int|float|string|bool)\\s*(?=\\()"
        },
        {
          "name": "support.type.primitive.xray",
          "match": "\\b(int|int8|int16|int32|int64|byte|uint8|uint16|uint32|uint64|float|float32|float64|string|bool|rune)\\b"
        },
        {
          "name": "support.type.builtin.xray",
          "match": "\\b(Array|Map|Set|Slice|Json|Channel|BigInt|Range|StringBuilder|Regex|RegexMatch|Path|Ptr|MutPtr|OsBarrier|OsCondvar|OsMutex|OsOnce|OsRwLock|NetConn|NetListener|Task|Thread|WorkQueue|CountdownLatch|EventCount|ResultGroup|Semaphore|Recv|SendResult|TaskResult|TaskStatus|Result|Atomic|Ordering|Endian|Type|PanicInfo|Utf8Error|StringSliceError|CompressionError|CryptoError)\\b"
        }
      ]
    },
    "stdlib-module": {
      "patterns": [
        {
          "comment": "Standard library module prefix, e.g. io.readFile / http.listen",
          "match": "\\b(base64|cluster|compress|crypto|csv|datetime|encoding|http|io|log|math|mem|net|os|parallel|path|regex|runtime|simd|strconv|sync|sys|text|time|toml|url|ws|xml|yaml)\\s*(?=\\.)",
          "name": "support.module.xray"
        },
        {
          "comment": "Global runtime objects",
          "match": "\\b(Coro|CoroPool|Json|Reflect|Type)\\s*(?=\\.)",
          "name": "support.class.xray"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.xray",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.language.null.xray",
          "match": "\\bnull\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.nullish.xray",
          "match": "\\?\\?"
        },
        {
          "name": "keyword.operator.optional-chaining.xray",
          "match": "\\?\\."
        },
        {
          "name": "keyword.operator.comparison.xray",
          "match": "(===|!==|==|!=|<=|>=|<|>)"
        },
        {
          "name": "keyword.operator.logical.xray",
          "match": "(&&|\\|\\||!)"
        },
        {
          "name": "keyword.operator.arithmetic.xray",
          "match": "(\\+\\+|--|\\+|-|\\*\\*|\\*|/|%)"
        },
        {
          "name": "keyword.operator.bitwise.xray",
          "match": "(<<|>>|&|\\||\\^|~)"
        },
        {
          "name": "keyword.operator.assignment.xray",
          "match": "(=|\\+=|-=|\\*=|/=|%=|&=|\\|=|\\^=|<<=|>>=)"
        },
        {
          "name": "keyword.operator.arrow.xray",
          "match": "->"
        },
        {
          "name": "keyword.operator.range.xray",
          "match": "\\.\\.(?:=|\\.)?"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "comment": "Built-in global functions",
          "name": "support.function.builtin.xray",
          "match": "\\b(print|dump|typeOf|typeName|assert|assert_eq|assert_ne|assert_true|assert_false|assert_throws|int|float|string|bool|rune|copy|chr|Coro)\\s*(?=\\()"
        },
        {
          "comment": "Coroutine / concurrency intrinsics used as call sites",
          "name": "support.function.concurrency.xray",
          "match": "\\b(go|await|defer)\\s*(?=\\()"
        },
        {
          "comment": "Module path after import / from (e.g. import http.server)",
          "match": "\\b(import|from)\\s+([a-zA-Z_][a-zA-Z0-9_\\.]*)",
          "captures": {
            "1": { "name": "keyword.module.xray" },
            "2": { "name": "entity.name.module.xray" }
          }
        },
        {
          "name": "entity.name.function.xray",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()"
        }
      ]
    },
    "variables": {
      "patterns": [
        {
          "comment": "Wildcard pattern in match expressions",
          "name": "variable.language.wildcard.xray",
          "match": "\\b_\\b"
        },
        {
          "name": "variable.other.xray",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
        }
      ]
    }
  }
}
