{
  "Anonymous Function": {
    "prefix": [
      "fn",
      "func",
      "function"
    ],
    "body": [
      "fn(${1:params}) {",
      "\t$0",
      "}"
    ],
    "description": "Anonymous function"
  },
  "Named Function": {
    "prefix": [
      "fnn",
      "function"
    ],
    "body": [
      "fn ${1:name}(${2:params}) {",
      "\t$0",
      "}"
    ],
    "description": "Named function"
  },
  "Arrow Function": {
    "prefix": [
      "arrow",
      "->"
    ],
    "body": [
      "(${1:params}) -> ${0:expr}"
    ],
    "description": "Arrow function"
  },
  "Arrow Function Block": {
    "prefix": [
      "arrowb"
    ],
    "body": [
      "(${1:params}) -> {",
      "\t$0",
      "}"
    ],
    "description": "Arrow function with block"
  },
  "Export Function": {
