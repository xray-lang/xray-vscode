      "\t${1:msg} from ${2:ch} -> {",
      "\t\t$0",
      "\t}",
      "\tafter ${3:1000} -> {",
      "\t\tprint(\"timeout\")",
      "\t}",
      "\t_ -> {",
      "\t\tprint(\"idle\")",
      "\t}",
      "}"
    ],
    "description": "Select statement"
  },
