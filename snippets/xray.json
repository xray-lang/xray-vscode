  "Go With Return Channel": {
    "prefix": [
      "gochan"
    ],
    "body": [
      "shared ${1:done} = Channel<${2:int}>()",
      "go fn() {",
      "\t$0",
      "\t${1:done}.send(${3:0})",
      "}()",
      "var ${4:result} = match ${1:done}.recv() {",
      "\tRecv.Value(value) -> value",
      "\tRecv.Closed -> ${5:0}",
      "\t_ -> ${5:0}",
      "}"
    ],
    "description": "Coroutine with channel-based completion signal"
  },
  "Scope Concurrency": {
    "prefix": [
      "scopeall"
    ],
    "body": [
      "scope {",
      "\tgo fn() { $1 }()",
      "\tgo fn() { $2 }()",
      "\t$0",
      "} // all goroutines joined here",
      ""
    ],
    "description": "Structured concurrency scope that waits for all children"
  },
  "Await Timeout Guarded": {
    "prefix": [
      "awaitt"
    ],
    "body": [
      "match ${1:task}.awaitTimeout(${2:5000}) {",
      "\tTaskResult.Success(${3:value}) -> $0",
      "\tTaskResult.Timeout -> print(\"timeout\")",
      "\tTaskResult.Cancelled -> print(\"cancelled\")",
      "\tTaskResult.Failed(${4:err}) -> print(${4:err})",
      "\tTaskResult.Pending -> unreachable()",
      "}"
    ],
    "description": "await with timeout result handling"
  },
