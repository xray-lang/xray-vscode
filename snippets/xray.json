  },
  "Atomic CAS": {
    "prefix": [
      "cas",
      "compareexchange"
    ],
    "body": [
      "var (${1:old}, ${2:ok}) = ${3:counter}.compareExchange(${4:expected}, ${5:desired})"
    ],
    "description": "Compare-and-exchange on atomic"
  },
  "Select": {
    "prefix": [
