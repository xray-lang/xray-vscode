  },
  "Match Tuple Pattern": {
    "prefix": [
      "matchtuple"
    ],
    "body": [
      "match (${1:tuple}) {",
      "\t(${2:0}, ${3:_}) -> ${4:result1}",
      "\t(${5:x}, ${6:y}) if (${5:x} == ${6:y}) -> ${7:result2}",
      "\t_ -> ${0:default}",
      "}"
    ],
    "description": "Match expression with tuple patterns"
  },
