    ],
    "description": "Create a channel"
  },
  "Channel Send/Recv": {
    "prefix": [
      "chansend",
      "chanrecv"
    ],
    "body": [
      "${1:ch}.send(${2:value})",
      "match ${1:ch}.recv() {",
      "\tRecv.Value(${3:value}) -> $0",
      "\tRecv.Closed -> break",
      "\t_ -> unreachable()",
      "}"
    ],
    "description": "Channel send and receive"
  },
  "Atomic": {
    "prefix": [
