  "HTTP Route": {
    "prefix": [
      "route",
      "http.route"
    ],
    "body": [
      "http.route(\"${1:GET}\", \"${2:/}\", fn(req) {",
      "\t$0",
      "\treturn \"OK\"",
      "})"
