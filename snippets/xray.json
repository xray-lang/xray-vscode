    "body": [
      "try {",
      "\t$0",
      "} catch (${1:e}) {",
      "\tprint(\"Error: \" + ${1:e})",
      "} catch panic {",
      "\tprint(\"Runtime fault\")",
      "}"
    ],
    "description": "Try-catch with panic handler"
  },
