# Source / dev tooling — never ship these to the marketplace.
src/**
test/**
tests/**
scripts/**
.github/**
.vscode/**
.vscode-test/**
.git/**
.gitignore
.gitattributes
.editorconfig
**/.eslintrc.*
**/.prettierrc*
esbuild.config.mjs
**/tsconfig.json
**/tsconfig.*.json

# Generated / artifact files.
*.vsix
**/*.map
**/*.ts
!out/**/*.js
!out/**/*.js.map
**/.DS_Store
package-lock.json
yarn.lock
pnpm-lock.yaml

# bin/ is intentionally NOT excluded — CI populates it with the
# platform-specific xray binary right before packaging.
